# ─── Database ────────────────────────────────────────────────────────────────
# asyncpg connection string — Railway auto-provisions this in production
DATABASE_URL=postgresql+asyncpg://deepsearch:deepsearch@localhost:5432/deepsearch

# ─── CRM Integration (optional) ──────────────────────────────────────────────
# Uses NullAdapter by default (logs and acknowledges, no external call)
# Replace with a real adapter class when a CRM is chosen
CRM_ADAPTER_CLASS=src.integrations.crm.null_adapter.NullAdapter
# CRM_API_KEY=

# ─── Booking (cal.eu) ────────────────────────────────────────────────────────
# Your cal.eu event type URL — booking links are built by appending pre-fill
# query params (name/email). No API key needed.
# Required in production.
BOOKING_EVENT_URL=https://cal.eu/sma-sam-hxsd97/30min

# ─── Email ───────────────────────────────────────────────────────────────────
# All four below are REQUIRED in production (fail-fast at startup); optional in dev.
# API key from https://resend.com for transactional emails
# RESEND_API_KEY=
# Sender address — must be a Resend-verified domain (or onboarding@resend.dev for testing)
# EMAIL_FROM_ADDRESS=DeepSearch <notifications@yourdomain.com>
# Commercial Team inbox that receives Operator Notifications
# INSIDE_NOTIFICATION_EMAIL=team@yourdomain.com

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
# JSON array of allowed CORS origins — pydantic-settings v2 requires JSON format
# for list[str] fields; bare comma-separated strings are NOT valid JSON.
CORS_ORIGINS=["https://deepsearchch-chatbot-frontend.vercel.app"]
LOG_LEVEL=INFO

# ─── Railway sets PORT automatically in production ────────────────────────────
# PORT=8000
