<!DOCTYPE html>
<html lang="it" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Nuovo Lead – DeepSearch</title>
  <style>
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; background-color: #F2F4F8; }

    .ds-label {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #9CA3AF;
    }
    .ds-value {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: #111827;
      line-height: 1.5;
    }
    .ds-value-missing {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: #9CA3AF;
      font-style: italic;
    }

    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-family: 'Inter', Arial, sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
    }
    .badge-blue   { background: #DBEAFE; color: #1D4ED8; border: 1px solid #93C5FD; }
    .badge-green  { background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7; }
    .badge-purple { background: #EDE9FE; color: #5B21B6; border: 1px solid #C4B5FD; }
    .badge-amber  { background: #FEF3C7; color: #92400E; border: 1px solid #FCD34D; }

    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .col-half { width: 100% !important; display: block !important; }
      .col-half td { padding-bottom: 16px !important; }
    }
  </style>
</head>
<body>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" bgcolor="#F2F4F8">
    <tr>
      <td align="center" style="padding: 32px 16px;">

        <table class="email-container" role="presentation" width="600" cellpadding="0" cellspacing="0"
               style="background-color: #FFFFFF; border: 1px solid #E2E6EF; border-radius: 12px; overflow: hidden;">

          <!-- Alert strip -->
          <tr>
            <td style="background: #EEF4FF; border-bottom: 1px solid #C7D9FD; padding: 12px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <span style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; color: #6B7280;">
                      {% if data_ora %}Ricevuto il <strong style="color: #111827;">{{ data_ora }}</strong>{% endif %}
                      {% if source_flow %}&nbsp;·&nbsp; Flusso <strong style="color: #111827;">{{ source_flow }}</strong>{% endif %}
                    </span>
                  </td>
                  <td align="right">
                    <span class="badge badge-green">{{ request_type_label }}</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Section: Contact Info -->
          <tr>
            <td style="padding: 28px 32px 0 32px;">
              <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #1B6FEB; margin: 0 0 16px 0;">
                Dati di Contatto
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background: #F8F9FC; border: 1px solid #E2E6EF; border-radius: 10px; overflow: hidden;">

                <!-- Row 1: Nome + Azienda -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Nome</p>
                    <p class="ds-value" style="margin: 0;">{{ nome }}</p>
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Azienda</p>
                    <p class="ds-value" style="margin: 0;">{{ azienda }}</p>
                  </td>
                </tr>

                <!-- Row 2: Email + Telefono -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Email</p>
                    <p style="margin: 0;">
                      <a href="mailto:{{ email }}" style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; color: #1D4ED8; text-decoration: none;">{{ email }}</a>
                    </p>
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Telefono</p>
                    {% if telefono %}
                    <p class="ds-value" style="margin: 0;">{{ telefono }}</p>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">Non fornito</p>
                    {% endif %}
                  </td>
                </tr>

                <!-- Row 3: Ruolo + Paese -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Ruolo professionale</p>
                    {% if ruolo %}
                    <p class="ds-value" style="margin: 0;">{{ ruolo }}</p>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">Non specificato</p>
                    {% endif %}
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Paese</p>
                    {% if paese %}
                    <p class="ds-value" style="margin: 0;">{{ paese }}</p>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">Non specificato</p>
                    {% endif %}
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <!-- Section: Qualification Profile -->
          <tr>
            <td style="padding: 8px 32px 0 32px;">
              <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #1B6FEB; margin: 0 0 16px 0;">
                Profilo di Qualificazione
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background: #F8F9FC; border: 1px solid #E2E6EF; border-radius: 10px; overflow: hidden;">

                <!-- Row 1: Tipo soggetto + Obiettivo -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 6px 0;">Tipo soggetto</p>
                    {% if subject_type %}
                    <span class="badge badge-purple">{{ subject_type }}</span>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 6px 0;">Obiettivo primario</p>
                    {% if intent %}
                    <span class="badge badge-blue">{{ intent }}</span>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                </tr>

                <!-- Row 2: Natura richiesta + Funzione -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 6px 0;">Natura della richiesta</p>
                    {% if request_nature %}
                    <span class="badge badge-blue">{{ request_nature }}</span>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 6px 0;">Funzione</p>
                    {% if func_role %}
                    <span class="badge badge-purple">{{ func_role }}</span>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                </tr>

                <!-- Row 3: Area geografica + Tipo esigenza -->
                <tr>
                  <td class="col-half" width="50%" style="padding: 16px 20px; border-right: 1px solid #E2E6EF; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 4px 0;">Area geografica</p>
                    {% if geo_area %}
                    <p class="ds-value" style="margin: 0;">{{ geo_area }}</p>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                  <td class="col-half" width="50%" style="padding: 16px 20px; vertical-align: top;">
                    <p class="ds-label" style="margin: 0 0 6px 0;">Tipo esigenza</p>
                    {% if need_type %}
                    <span class="badge badge-amber">{{ need_type }}</span>
                    {% else %}
                    <p class="ds-value-missing" style="margin: 0;">—</p>
                    {% endif %}
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          {% if note %}
          <!-- Section: Note / Custom Request -->
          <tr>
            <td style="padding: 8px 32px 0 32px;">
              <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #1B6FEB; margin: 0 0 16px 0;">
                Note / Richiesta
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 32px 28px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background: #F8F9FC; border: 1px solid #93C5FD; border-left: 3px solid #1B6FEB; border-radius: 10px;">
                <tr>
                  <td style="padding: 18px 20px;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; line-height: 1.6; color: #374151; margin: 0;">
                      {{ note }}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- Footer -->
          <tr>
            <td style="background: #F8F9FC; border-top: 1px solid #E2E6EF; padding: 20px 32px; border-radius: 0 0 12px 12px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; color: #9CA3AF; margin: 0; line-height: 1.6;">
                      Email automatica generata da <strong style="color: #6B7280;">DeepSearch Intelligence Widget</strong>
                      &nbsp;·&nbsp; Sorgente: <code style="background: #E2E6EF; padding: 1px 5px; border-radius: 3px; color: #6B7280; font-size: 10px;">deepsearch_chatbot_widget</code>
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>
</body>
</html>
