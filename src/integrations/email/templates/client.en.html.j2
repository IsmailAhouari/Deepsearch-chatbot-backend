<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Request received – DeepSearch</title>
  <style>
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; background-color: #F2F4F8; }

    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .hero-padding { padding: 32px 20px !important; }
      .section-padding { padding: 24px 20px !important; }
      .summary-col { width: 100% !important; display: block !important; border-right: none !important; }
      .feat-col { width: 100% !important; display: block !important; padding: 16px 20px !important; border-left: none !important; border-top: 1px solid #E2E6EF !important; }
      .feat-col-first { border-top: none !important; }
      .cta-text { display: block !important; padding-right: 0 !important; padding-bottom: 16px !important; }
      .cta-action { display: block !important; text-align: center !important; white-space: normal !important; }
      .cta-btn { display: block !important; width: 100% !important; text-align: center !important; box-sizing: border-box !important; }
    }
  </style>
</head>
<body>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" bgcolor="#F2F4F8">
    <tr>
      <td align="center" style="padding: 32px 16px;">

        <table class="email-container" role="presentation" width="600" cellpadding="0" cellspacing="0"
               style="background-color: #FFFFFF; border: 1px solid #E2E6EF; border-radius: 12px; overflow: hidden;">

          <!-- Hero -->
          <tr>
            <td class="hero-padding" style="padding: 48px 32px 36px 32px; text-align: center; background: #FFFFFF;">

              <!-- Success icon -->
              <table role="presentation" cellpadding="0" cellspacing="0" align="center" style="margin-bottom: 24px;">
                <tr>
                  <td style="background: #D1FAE5; border: 1px solid #6EE7B7; border-radius: 50%; width: 64px; height: 64px; text-align: center; vertical-align: middle;">
                    <span style="font-size: 28px; line-height: 64px; display: block; color: #065F46;">✓</span>
                  </td>
                </tr>
              </table>

              <h1 style="font-family: 'Inter', Arial, sans-serif; font-size: 26px; font-weight: 700; color: #111827; margin: 0 0 12px 0; letter-spacing: -0.03em; line-height: 1.2;">
                Request received,<br />{{ nome }}
              </h1>
              <p style="font-family: 'Inter', Arial, sans-serif; font-size: 15px; color: #6B7280; margin: 0 auto; max-width: 400px; line-height: 1.6;">
                {% if request_type == "demo" %}
                Your interest in a DeepSearch demo has been registered. Our team will get in touch within 1 business day.
                {% elif request_type == "contact" %}
                Your contact request has been forwarded to our team. We will reply as soon as possible.
                {% else %}
                Your custom request has been received. A specialist will reach out to better understand your needs.
                {% endif %}
              </p>
            </td>
          </tr>

          <!-- Summary card -->
          <tr>
            <td class="section-padding" style="padding: 0 32px 28px 32px; background: #FFFFFF;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background: #F8F9FC; border: 1px solid #E2E6EF; border-radius: 10px; overflow: hidden;">

                <tr>
                  <td colspan="2" style="padding: 14px 20px; border-bottom: 1px solid #E2E6EF;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9CA3AF; margin: 0;">
                      Your request summary
                    </p>
                  </td>
                </tr>

                <!-- Name + Company -->
                <tr>
                  <td class="summary-col" width="50%" style="padding: 14px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #9CA3AF; margin: 0 0 3px 0;">Name</p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; color: #111827; margin: 0;">{{ nome }}</p>
                  </td>
                  <td class="summary-col" width="50%" style="padding: 14px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #9CA3AF; margin: 0 0 3px 0;">Company</p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; color: #111827; margin: 0;">{{ azienda }}</p>
                  </td>
                </tr>

                <!-- Request type + Area of interest -->
                <tr>
                  <td class="summary-col" width="50%" style="padding: 14px 20px; border-right: 1px solid #E2E6EF; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #9CA3AF; margin: 0 0 6px 0;">Request type</p>
                    <span style="display: inline-block; padding: 3px 10px; border-radius: 20px; font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 600; background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7;">
                      {% if request_type == "demo" %}Demo
                      {%- elif request_type == "contact" %}Contact
                      {%- else %}Custom request{% endif %}
                    </span>
                  </td>
                  <td class="summary-col" width="50%" style="padding: 14px 20px; border-bottom: 1px solid #E2E6EF; vertical-align: top;">
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #9CA3AF; margin: 0 0 6px 0;">Area of interest</p>
                    {% set interest = intent or request_nature %}
                    {% if interest %}
                    <span style="display: inline-block; padding: 3px 10px; border-radius: 20px; font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 600; background: #DBEAFE; color: #1D4ED8; border: 1px solid #93C5FD;">
                      {{ interest }}
                    </span>
                    {% else %}
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 13px; color: #9CA3AF; margin: 0; font-style: italic;">—</p>
                    {% endif %}
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <!-- Divider with label -->
          <tr>
            <td style="padding: 0 32px 24px 32px; background: #FFFFFF;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td width="50%" style="vertical-align: middle;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="border-top: 1px solid #E2E6EF; line-height: 0; font-size: 0;">&nbsp;</td></tr></table>
                  </td>
                  <td style="padding: 0 16px; white-space: nowrap; text-align: center; vertical-align: middle;">
                    <span style="font-family: 'Inter', Arial, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #9CA3AF;">What happens next</span>
                  </td>
                  <td width="50%" style="vertical-align: middle;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="border-top: 1px solid #E2E6EF; line-height: 0; font-size: 0;">&nbsp;</td></tr></table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Next steps -->
          <tr>
            <td class="section-padding" style="padding: 0 32px 28px 32px; background: #FFFFFF;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">

                <!-- Step 1 -->
                <tr>
                  <td valign="top">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td valign="top" width="40" style="padding-right: 14px; padding-top: 2px;">
                          <table role="presentation" cellpadding="0" cellspacing="0">
                            <tr>
                              <td style="background: #1B6FEB; border-radius: 50%; width: 28px; height: 28px; text-align: center; vertical-align: middle;">
                                <span style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; font-weight: 700; color: #ffffff; line-height: 28px; display: block;">1</span>
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 3px 0;">Request review</p>
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 13px; color: #6B7280; margin: 0; line-height: 1.5;">Our team has received your request and is reviewing it to identify the right fit for your needs.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Connector -->
                <tr>
                  <td style="padding-left: 19px; padding-top: 8px; padding-bottom: 8px;">
                    <div style="width: 1px; height: 16px; background: #E2E6EF; margin-left: 1px;"></div>
                  </td>
                </tr>

                <!-- Step 2 -->
                <tr>
                  <td valign="top">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td valign="top" width="40" style="padding-right: 14px; padding-top: 2px;">
                          <table role="presentation" cellpadding="0" cellspacing="0">
                            <tr>
                              <td style="background: #1B6FEB; border-radius: 50%; width: 28px; height: 28px; text-align: center; vertical-align: middle;">
                                <span style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; font-weight: 700; color: #ffffff; line-height: 28px; display: block;">2</span>
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td valign="top">
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 3px 0;">
                            {% if request_type == "demo" %}Personalised demo session
                            {%- elif request_type == "contact" %}Response to your enquiry
                            {%- else %}Tailored proposal{% endif %}
                          </p>
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 13px; color: #6B7280; margin: 0; line-height: 1.5;">
                            {% if request_type == "demo" %}We will show you how DeepSearch addresses your specific intelligence needs.
                            {%- elif request_type == "contact" %}Our team will provide all the information you need and a suitable evaluation path.
                            {%- else %}Based on your requirements, we will build a proposal tailored to your operational context.{% endif %}
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          {% if request_type == "demo" and booking_url %}
          <!-- Booking CTA (cal.eu) -->
          <tr>
            <td style="padding: 0 32px 32px 32px; background: #FFFFFF;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background: #EEF4FF; border: 1px solid #93C5FD; border-radius: 10px;">
                <tr>
                  <td style="padding: 24px 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td class="cta-text" valign="middle" style="padding-right: 20px;">
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 4px 0;">Book your session now</p>
                          <p style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; color: #6B7280; margin: 0; line-height: 1.5;">Choose a time that works for you — 30 minutes, no obligation.</p>
                        </td>
                        <td class="cta-action" valign="middle" align="right" style="white-space: nowrap;">
                          <a href="{{ booking_url }}"
                             class="cta-btn"
                             style="display: inline-block; background: #1B6FEB; color: #ffffff; font-family: 'Inter', Arial, sans-serif; font-size: 13px; font-weight: 600; text-decoration: none; padding: 11px 22px; border-radius: 6px; white-space: nowrap;">
                            Book Demo &rarr;
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- Value prop section -->
          <tr>
            <td style="background: #F8F9FC; border-top: 1px solid #E2E6EF; padding: 28px 32px;">
              <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9CA3AF; margin: 0 0 18px 0;">
                What you will find in DeepSearch
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <!-- Feature 1 -->
                  <td class="feat-col feat-col-first" valign="top" width="33%" style="padding-right: 12px; text-align: center;">
                    <table role="presentation" cellpadding="0" cellspacing="0" align="center" style="margin: 0 auto 12px auto;">
                      <tr>
                        <td style="background: #1B6FEB; border-radius: 50%; width: 40px; height: 40px; text-align: center; vertical-align: middle;">
                          <span style="font-family: Arial, sans-serif; font-size: 18px; color: #ffffff; line-height: 40px; display: block;">&#9906;</span>
                        </td>
                      </tr>
                    </table>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; font-weight: 600; color: #111827; margin: 0 0 4px 0;">Deep intelligence</p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; color: #6B7280; margin: 0; line-height: 1.5;">Advanced analysis on companies, individuals and relationship networks.</p>
                  </td>
                  <!-- Feature 2 -->
                  <td class="feat-col" valign="top" width="33%" style="padding-right: 12px; padding-left: 12px; border-left: 1px solid #E2E6EF; text-align: center;">
                    <table role="presentation" cellpadding="0" cellspacing="0" align="center" style="margin: 0 auto 12px auto;">
                      <tr>
                        <td style="background: #1B6FEB; border-radius: 50%; width: 40px; height: 40px; text-align: center; vertical-align: middle;">
                          <span style="font-family: Arial, sans-serif; font-size: 18px; color: #ffffff; line-height: 40px; display: block;">&#9193;</span>
                        </td>
                      </tr>
                    </table>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; font-weight: 600; color: #111827; margin: 0 0 4px 0;">Real-time results</p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; color: #6B7280; margin: 0; line-height: 1.5;">Instant answers from structured and open sources.</p>
                  </td>
                  <!-- Feature 3 -->
                  <td class="feat-col" valign="top" width="33%" style="padding-left: 12px; border-left: 1px solid #E2E6EF; text-align: center;">
                    <table role="presentation" cellpadding="0" cellspacing="0" align="center" style="margin: 0 auto 12px auto;">
                      <tr>
                        <td style="background: #1B6FEB; border-radius: 50%; width: 40px; height: 40px; text-align: center; vertical-align: middle;">
                          <span style="font-family: Arial, sans-serif; font-size: 18px; color: #ffffff; line-height: 40px; display: block;">&#10003;</span>
                        </td>
                      </tr>
                    </table>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; font-weight: 600; color: #111827; margin: 0 0 4px 0;">Compliance-ready</p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; color: #6B7280; margin: 0; line-height: 1.5;">Designed for regulated environments: AML, KYC, Due Diligence.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background: #FFFFFF; border-top: 1px solid #E2E6EF; padding: 20px 32px; border-radius: 0 0 12px 12px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 12px; color: #6B7280; margin: 0 0 8px 0;">
                      Questions? Write to us at&nbsp;
                      <a href="mailto:ask@deepsearch.ch" style="color: #1D4ED8; text-decoration: none;">ask@deepsearch.ch</a>
                    </p>
                    <p style="font-family: 'Inter', Arial, sans-serif; font-size: 11px; color: #9CA3AF; margin: 0; line-height: 1.6;">
                      You received this email because you filled out a form on <strong style="color: #6B7280;">deepsearch.ch</strong>.
                      If this wasn't you, you can safely ignore this message.
                      <br />
                      &copy; 2026 INTELLIGENCE INSIDE SA
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>
</body>
</html>
